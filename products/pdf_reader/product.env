# pdf_reader 非敏感构建配置（敏感信息走 GitHub Secrets，见 README.md）
PRODUCT_NAME=pdf_reader
REPO_URL=code.zsrhkj.com/zsrhkj/pdf-reader.git
DEFAULT_REF=main
PLATFORMS=win-x64,osx-arm64,linux-x64
BUILD_WIN=scripts/build-win.sh
BUILD_MAC=scripts/build-mac.sh
BUILD_LINUX=scripts/build-linux.sh
ARTIFACT_GLOB=build/publish/**
VERSION_SOURCE=src/PdfReader.App/PdfReader.App.csproj
DOTNET_VERSION=8.0.x
